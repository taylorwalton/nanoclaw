# Ollama MCP — optional configuration
#
# Leave this file as-is if Ollama is running on the default port (11434)
# on the same machine as NanoClaw (or the Docker host).
#
# OLLAMA_HOST: Override the Ollama endpoint.
#   Default inside container: http://host.docker.internal:11434
#   Default on host:          http://localhost:11434
#
# Examples:
#   OLLAMA_HOST=http://192.168.1.50:11434   # remote Ollama server
#   OLLAMA_HOST=http://localhost:11434       # force localhost
#
# OLLAMA_HOST=http://host.docker.internal:11434
